# ------------------------------------------------------------------
# Kanka Community Edition
# ------------------------------------------------------------------
#
# Notes
# - Replace placeholder passwords and keys before deploying to production,
#   you can use the provided gen-passwords.sh to do so.
# - Keep secrets out of version control; use a secrets manager when possible.
# - For production: set APP_ENV=production, enable HTTPS, and use robust credentials.
# ------------------------------------------------------------------


# -------------------------
# Application settings
# -------------------------
APP_NAME="Kanka Community Edition"

# Public URL where Kanka is reachable and contact information.
APP_URL=http://localhost
APP_EMAIL=you@example.com

# Allow users to self-register. Set to "false" to disable public signups.
APP_REGISTRATION_ENABLED=true

# Require an invitation to register. 
When true, users need the invitation password set here.
APP_INVITATION_REQUIRED=false
APP_INVITATION_PASSWORD=

# Port the application listens on inside the container.
# Do not expose this port to the internet!
# Instead point a reverse proxy to this port.
APP_PORT=8081

# UID and GID used by the container to match host file permissions.
APP_USER_ID=1000
APP_GROUP_ID=1000

# Laravel environment. 
#   - Use "local" only for the set-up process and testing.
#   - Use "production" for live systems.
APP_ENV=local

# Application encryption key (should be generated automatically).
APP_KEY=

# Host path for persistent application data 
KANKA_CE_DATA=/opt/kanka-data

FRONT_DOMAIN="${APP_URL}"


# -------------------------
# Database
# -------------------------
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=kanka
DB_USERNAME=sail
DB_PASSWORD=password
DB_ROOT_PASSWORD=password


# -------------------------
# Cache, sessions, queues
# -------------------------
BROADCAST_DRIVER=reverb
CACHE_DRIVER=redis
CACHE_PREFIX=kanka
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_DRIVER=sync


# -------------------------
# Redis
# -------------------------
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379


# -------------------------
# Mail
# -------------------------
MAIL_DRIVER=log
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@kanka.io
MAIL_FROM_NAME="${APP_NAME}"


# -------------------------
# Frontend / icons
# -------------------------
# Important: 
# In order for the icons to load, you need to provide a key here.
# 1.) Go to https://fontawesome.com/start to create an account.
# 2.) Create a (free) kit.
# 3.) Go to https://fontawesome.com/kits
# 3.1) Select you kit
# 3.2) copy the id either from the url: https://fontawesome.com/kits/<kit-id>/setup
#      or from the example: <script src="https://kit.fontawesome.com/<kit-id>.js" crossorigin="anonymous"></script>
#      and paste only the <kit-id> here.
FONTAWESOME_KIT=


# -------------------------
# File storage (MinIO / S3)
# -------------------------

# MinIO/S3 endpoint and ports.
FILESYSTEM_DRIVER=minio
MINIO_URL=http://localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=8900

# MinIO credentials and bucket name.
MINIO_ACCESS_KEY_ID=sail
MINIO_BUCKET=kanka
MINIO_PASSWORD=password


# -------------------------
# Search (Meilisearch)
# -------------------------
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=password


# -------------------------
# WebSockets (Reverb)
# (Currently not in use)
# -------------------------

# Host and ports for the Reverb server.
REVERB_HOST=localhost
REVERB_SERVER_PORT=8080
REVERB_PORT=8080

# Reverb (WebSocket) credentials and host configuration.
REVERB_APP_ID=144165
REVERB_APP_KEY=kanka
REVERB_APP_SECRET=websockets123

# Scheme used by Reverb (http or https).
REVERB_SCHEME=http

# Vite frontend variables (mirrors Reverb settings for the browser).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
